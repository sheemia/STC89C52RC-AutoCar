   8          //陀螺仪直线 PID 专用参数
   9          // 使用整数运算优化性能
  10          int Gyro_Kp_Mult = 3;    // P 分子
  11          int Gyro_Kd_Mult = 25;   // D 分子
  12          int Gyro_Divisor = 1000;  // 公共分母
  13          
  14          // 陀螺仪 PID 过程变量
  15          static short idata gyro_last_error = 0;
