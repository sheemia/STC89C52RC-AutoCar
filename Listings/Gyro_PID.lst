  22   1      }
  23          
  24          //陀螺仪直线 PID 控制循环
  25          void PID_Gyro_Straight_Loop()
  26          {
  27   1          short error;
  28   1          long p_term, d_term;
  29   1          char pid_output;
  30   1          char final_speed_L, final_speed_R;
  31   1      
  32   1          //获取误差
  33   1          error = 0 - Get_Relative_Yaw(); 
  34   1      
  35   1          //计算 P 项
  36   1          p_term = (long)error * Gyro_Kp_Mult;
  37   1      
  38   1          //计算 D 项
  39   1          d_term = (long)(error - gyro_last_error) * Gyro_Kd_Mult;
  40   1      
  41   1          //计算总输出
  42   1          pid_output = (int)((p_term + d_term) / Gyro_Divisor);
  43   1      
  44   1          //更新历史误差
  45   1          gyro_last_error = error;
  46   1      
  47   1          //输出限幅
  48   1          if(pid_output > 45) pid_output = 45;
  49   1          if(pid_output < -45) pid_output = -45;
  50   1      
  51   1          //执行电机控制
  52   1          final_speed_L = Base_Speed - pid_output;
  53   1          final_speed_R = Base_Speed + pid_output;
  54   1      
