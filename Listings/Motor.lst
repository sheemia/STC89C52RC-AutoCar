  23          /*********** 定时器0初始化（PWM用） ***********/
  24          void Timer0_Init(void)//100us
  25          {
  26   1        TMOD &= 0xF0;     //设置定时器模式
  27   1        TMOD |= 0x01;     //设置定时器模式
  28   1        TL0 = 0xA4;       //设置定时初始值
  29   1        TH0 = 0xFF;       //设置定时初始值
  30   1        TF0 = 0;        //清除TF0标志
  31   1        TR0 = 1;        //定时器0开始计时
  32   1      
  33   1        ET0=1;
  34   1        EA=1;
  35   1        PT0=0;
  36   1      }
  37          
  38          /*********** 定时器0中断函数（PWM输出） ***********/
  39          void Timer0_Routine(void) interrupt 1
  40          {
  41   1        TL0 = 0xA4;   //设置定时初值
  42   1        TH0 = 0xFF;   //设置定时初值
  43   1        pwmCountA++;
  44   1        pwmCountB++;
  45   1        if(pwmCountA >= 100) pwmCountA = 0;
  46   1        if(pwmCountB >= 100) pwmCountB = 0;
  47   1        PWMA = (pwmCountA < speedA) ? 1 : 0;
  48   1        PWMB = (pwmCountB < speedB) ? 1 : 0;
  49   1      }
