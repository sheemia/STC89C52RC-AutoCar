 117          void LCD_ShowNumber(unsigned char Row,unsigned char Column,unsigned int Number)
 118          {
 119   1        unsigned char i,Length=0;
 120   1        unsigned int Temp_Number;
 121   1        LCD_SetCursor(Row,Column);
 122   1        Temp_Number=Number;
 123   1        
 124   1        if(Temp_Number==0) Length=1;
 125   1        else
 126   1        {
 127   2          while(Temp_Number>0)
 128   2          {
 129   3            Temp_Number/=10;
 130   3            Length++;
 131   3          }
 132   2        }
 133   1        
 134   1        for(i=Length;i>0;i--)
 135   1        {
 136   2          LCD_WriteData('0'+Number/Pow(10,i-1)%10);
 137   2        }
 138   1      }
